DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sharing_minds
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sharing_minds

# LiveKit Cloud
# Server-side host can be https://<project>.livekit.cloud or ws(s):// and will be normalized.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=
NEXT_PUBLIC_LIVEKIT_WS_URL=

# Recording rollout
# disabled = no automatic recording requests
# cloud = use LiveKit Cloud Egress with direct upload to object storage
LIVEKIT_RECORDING_MODE=disabled

# LiveKit Cloud Egress output (S3-compatible).
# For Supabase Storage, generate S3 access keys in Supabase and use the bucket below.
LIVEKIT_EGRESS_S3_ACCESS_KEY=
LIVEKIT_EGRESS_S3_SECRET_KEY=
LIVEKIT_EGRESS_S3_REGION=
LIVEKIT_EGRESS_S3_BUCKET=
LIVEKIT_EGRESS_S3_ENDPOINT=
LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=true

# Supabase variables remain optional for storage-related flows only.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

STORAGE_PROVIDER=supabase

# Payments
# dummy keeps the existing local/testing payment behavior.
# razorpay requires the Razorpay keys below and verifies both Checkout and webhooks.
PAYMENTS_PROVIDER=dummy
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MENTOR_ONBOARDING_FEE_INR=5000

# Infinity AI platform bridge
INFINITY_AI_ENABLED=false
INFINITY_AI_ANONYMOUS_ENABLED=true
INFINITY_AI_ANONYMOUS_EXPERT_PREVIEW_ENABLED=false
INFINITY_AI_CROSS_CHAT_MEMORY_ENABLED=false
INFINITY_AI_SERVICE_URL=http://127.0.0.1:8000
INFINITY_AI_INTERNAL_SECRET=
INFINITY_AI_REQUIRE_LLM=true
INFINITY_AI_TURN_CONTROLLER_ENABLED=false

# Infinity AI LLM routing
INFINITY_AI_LLM_PROVIDER=router
INFINITY_AI_LLM_PROVIDER_ORDER=groq,gemini
INFINITY_AI_LLM_API_KEY=
INFINITY_AI_LLM_MODEL=
INFINITY_AI_LLM_STRICT_STRUCTURED_OUTPUT=true
INFINITY_AI_LLM_MAX_RETRIES=1
INFINITY_AI_LLM_RATE_LIMIT_BACKOFF_SECONDS=0.75

# Groq is the preferred local/staging provider. Do not commit real keys.
INFINITY_AI_GROQ_API_KEY=
INFINITY_AI_GROQ_PLANNER_MODEL=openai/gpt-oss-20b
INFINITY_AI_GROQ_COMPOSER_MODEL=openai/gpt-oss-20b
INFINITY_AI_GROQ_EXTRACTOR_MODEL=openai/gpt-oss-20b
INFINITY_AI_GROQ_SUMMARIZER_MODEL=openai/gpt-oss-20b
INFINITY_AI_GROQ_REPAIR_MODEL=openai/gpt-oss-20b

# Azure AI Foundry / Azure OpenAI in Foundry. Do not commit real keys.
# Endpoint may be a Foundry Models endpoint, e.g. https://<resource>.services.ai.azure.com,
# an Azure OpenAI resource endpoint, e.g. https://<resource>.openai.azure.com,
# or a full Azure Responses URL, e.g. https://<resource>.cognitiveservices.azure.com/openai/responses?api-version=...
INFINITY_AI_AZURE_API_KEY=
INFINITY_AI_AZURE_ENDPOINT=
INFINITY_AI_AZURE_API_VERSION=2024-05-01-preview
INFINITY_AI_AZURE_MODEL=
INFINITY_AI_AZURE_PLANNER_MODEL=
INFINITY_AI_AZURE_COMPOSER_MODEL=
INFINITY_AI_AZURE_EXTRACTOR_MODEL=
INFINITY_AI_AZURE_SUMMARIZER_MODEL=
INFINITY_AI_AZURE_REPAIR_MODEL=
